        </mxCell>
        <mxCell id="kb-mq" value="mq/&#xa;KnowledgeDocumentChunkConsumer&#xa;(RocketMQ 事务消息 + 幂等消费)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="740" width="300" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kb-sched" value="schedule/&#xa;URL 源定时重分块（Redisson 分布式锁）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="740" width="210" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kb-dao" value="dao/ + domain/&#xa;KnowledgeBaseDO · KnowledgeDocumentDO · KnowledgeChunkDO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="810" width="740" height="50" as="geometry"/>
        </mxCell>

        <!-- user domain -->
        <mxCell id="usr" value="user/ — 认证与 RBAC (31 文件)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="860" y="620" width="700" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="usr-ctrl" value="controller/&#xa;AuthController · UserController&#xa;RoleController · SysDeptController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="880" y="660" width="330" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="usr-svc" value="service/&#xa;KbAccessService（RBAC 核心）&#xa;RoleService · SysDeptService · UserProfileLoader" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1230" y="660" width="310" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="usr-kb" value="KbAccessService 能力：&#xa;• getAccessibleKbIds(userId) → Redis 缓存&#xa;• checkAccess(kbId) / checkManageAccess(kbId)&#xa;• getMaxSecurityLevelForKb(userId, kbId)&#xa;• validateRoleAssignment / Last-SUPER_ADMIN 保护" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F5;strokeColor=#B85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="880" y="740" width="330" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="usr-dao" value="dao/ + domain/&#xa;UserDO · RoleDO · UserRoleDO · RoleKbRelationDO&#xa;SysDeptDO（表名 sys_dept 非 t_department）&#xa;RoleType: SUPER_ADMIN / DEPT_ADMIN / USER" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F5;strokeColor=#B85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1230" y="740" width="310" height="120" as="geometry"/>
