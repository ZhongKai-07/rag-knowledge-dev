        <mxCell id="ing-n1" value="FetcherNode&#xa;LocalFile / HttpUrl&#xa;S3 / Feishu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="345" width="130" height="70" as="geometry"/>
