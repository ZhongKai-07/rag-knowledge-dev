          <mxGeometry x="880" y="270" width="320" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ing-engine" value="engine/&#xa;IngestionEngine（节点链编排）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1220" y="270" width="320" height="55" as="geometry"/>
