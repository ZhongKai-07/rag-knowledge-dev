        <mxCell id="kb-ctrl" value="controller/&#xa;KnowledgeBaseController · KnowledgeDocumentController&#xa;KnowledgeChunkController · SpacesController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
