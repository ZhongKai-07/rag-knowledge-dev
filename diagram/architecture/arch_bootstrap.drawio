        <!-- Outbound arrow placeholder -->
        <mxCell id="outb" value="→ framework (Result/UserContext/TTL Trace/异常/幂等) · infra-ai (LLM/Embedding/Rerank) · Infrastructure (PG/Redis/MQ/向量库/RustFS)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontStyle=2;fontColor=#444;" vertex="1" parent="1">
