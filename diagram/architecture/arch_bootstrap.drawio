        <mxCell id="rag-core4" value="core/memory/&#xa;ConversationMemoryService&#xa;JDBC 持久化 + 摘要" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
