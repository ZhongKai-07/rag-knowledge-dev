<mxfile host="app.diagrams.net">
  <diagram id="arch-bootstrap" name="Bootstrap 业务域架构">
    <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t1" value="Bootstrap Layer — 按业务域组织的 Spring Boot 应用" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="每个域内部标准分层：controller/ → service/ → dao/ → domain/；域与域之间只读跨域聚合集中在 admin/" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=2;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1520" height="22" as="geometry"/>
        </mxCell>

        <!-- Inbound: REST/SSE -->
        <mxCell id="inb" value="Inbound — Spring MVC · SseEmitter · SaInterceptor (checkLogin only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="1500" height="50" as="geometry"/>
        </mxCell>

        <!-- Cross-cutting AOP -->
        <mxCell id="aop" value="AOP 切面：ChatRateLimitAspect（限流 + traceId 生成 + TTL 上下文） · RagTraceAspect（节点计时）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4C4;strokeColor=#D79B00;fontSize=11;fontStyle=2;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="1500" height="40" as="geometry"/>
        </mxCell>

        <!-- rag domain -->
        <mxCell id="rag" value="rag/ — RAG 问答核心 (194 文件)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="780" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="rag-ctrl" value="controller/&#xa;RAGChatController (SSE /rag/v3/chat)&#xa;ConversationController · IntentTreeController&#xa;RagTraceController · RagEvaluationController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="rag-svc" value="service/&#xa;RAGChatServiceImpl.streamChat()&#xa;（主编排：记忆→改写→意图→检索→Prompt→生成）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="450" y="270" width="370" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="rag-core1" value="core/intent/&#xa;IntentResolver&#xa;DefaultIntentClassifier" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="365" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="rag-core2" value="core/retrieve/&#xa;RetrievalEngine&#xa;MultiChannelRetrievalEngine&#xa;channels · postprocessors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
