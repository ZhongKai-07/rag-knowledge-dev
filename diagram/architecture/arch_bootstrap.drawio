        <mxCell id="ing-n2" value="ParserNode&#xa;Apache Tika 3.2&#xa;→ DocumentParserSelector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1025" y="345" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ing-n3" value="EnhancerNode&#xa;(可选)&#xa;文档级 LLM 增强" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#82B366;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="345" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ing-n4" value="ChunkerNode&#xa;ChunkingStrategy&#xa;+ EmbeddingService.batch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1345" y="345" width="195" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ing-n5" value="EnricherNode&#xa;(可选)&#xa;分块级 LLM 增强" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#82B366;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="430" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ing-n6" value="IndexerNode&#xa;VectorStoreService&#xa;.writeBatch()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1025" y="430" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ing-ctx" value="domain/&#xa;IngestionContext（贯穿节点的状态）&#xa;PipelineDefinition · NodeConfig" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="430" width="340" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ing-arrow" value="Fetcher → Parser → [Enhancer] → Chunker → [Enricher] → Indexer（顺序执行，配置驱动）" style="text;html=1;fillColor=#FFF5CE;strokeColor=#C9A227;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="880" y="515" width="660" height="55" as="geometry"/>
        </mxCell>

        <!-- knowledge -->
        <mxCell id="kb" value="knowledge/ — 知识库与文档管理 (61 文件)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="780" height="250" as="geometry"/>
