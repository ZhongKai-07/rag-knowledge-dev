        <mxCell id="kb-svc" value="service/&#xa;KnowledgeDocumentServiceImpl&#xa;CHUNK 模式 / PIPELINE 模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
