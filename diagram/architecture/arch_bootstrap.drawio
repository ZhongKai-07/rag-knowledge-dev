        </mxCell>
        <mxCell id="rag-dao" value="dao/ + domain/&#xa;Conversation · Message · TraceRun/Node · Evaluation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="445" y="515" width="385" height="55" as="geometry"/>
        </mxCell>

        <!-- ingestion domain -->
        <mxCell id="ing" value="ingestion/ — 文档 ETL 流水线 (64 文件)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
