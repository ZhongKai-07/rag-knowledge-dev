        <mxCell id="rag-core7" value="core/guidance/&#xa;IntentGuidanceService&#xa;歧义短路" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="440" width="160" height="60" as="geometry"/>
