        <mxCell id="rag-core8" value="core/mcp/&#xa;MCPToolExecutor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="440" width="180" height="60" as="geometry"/>
