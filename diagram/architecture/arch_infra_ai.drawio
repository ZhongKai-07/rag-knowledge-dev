<mxfile host="app.diagrams.net">
  <diagram id="arch-infra-ai" name="infra-ai 层详细">
    <mxGraphModel dx="1500" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t1" value="infra-ai — AI 能力抽象层（统一接口 · 模型路由 · 故障降级 · 流式桥接）" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1420" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="业务代码只注入 LLMService / EmbeddingService / RerankService，看不见具体供应商。" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=2;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1420" height="22" as="geometry"/>
        </mxCell>

        <!-- Caller -->
        <mxCell id="caller" value="Bootstrap 业务层（RAGChatServiceImpl · IngestionEngine · QueryRewriteService · IntentClassifier ...）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="1380" height="50" as="geometry"/>
        </mxCell>

        <!-- Interfaces -->
        <mxCell id="if-box" value="统一接口（Service 层 · Bootstrap 唯一注入点）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="1380" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="if-chat" value="LLMService&#xa;━━━━━━━━━━━━&#xa;chat(request) · chat(request, modelId)&#xa;streamChat(request, callback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="400" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="if-emb" value="EmbeddingService&#xa;━━━━━━━━━━━━&#xa;embed(text) · batchEmbed(texts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="500" y="220" width="400" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="if-rerank" value="RerankService&#xa;━━━━━━━━━━━━&#xa;rerank(query, docs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="920" y="220" width="500" height="75" as="geometry"/>
        </mxCell>

        <!-- Routing impls -->
        <mxCell id="r-box" value="Routing 实现（@Primary · 模型选择 · 故障降级）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="1380" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="r-chat" value="RoutingLLMService&#xa;━━━━━━━━━━━━&#xa;1. ModelSelector.select(request)&#xa;   候选按 priority 排序&#xa;2. ModelRoutingExecutor.execute(candidates, op)&#xa;   遇错切下一家 · 熔断跳过&#xa;3. ModelHealthStore 记录失败次数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="400" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="r-emb" value="RoutingEmbeddingService&#xa;━━━━━━━━━━━━&#xa;同套选择 + 降级机制&#xa;候选来自 ai.embedding.candidates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="500" y="370" width="400" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="r-rerank" value="RoutingRerankService&#xa;━━━━━━━━━━━━&#xa;候选用尽退回 NoopRerankClient（保持原序，设计上 graceful）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="920" y="370" width="500" height="110" as="geometry"/>
        </mxCell>

        <!-- Clients row -->
        <mxCell id="c-box" value="Client 接口 + 三家供应商实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="1380" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="c-chat-if" value="ChatClient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#9673A6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="180" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="c-chat-b" value="BaiLianChatClient&#xa;(qwen3-max 等)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="595" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="c-chat-o" value="OllamaChatClient&#xa;(本地模型)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="650" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="c-chat-s" value="SiliconFlowChatClient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="705" width="180" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="c-emb-if" value="EmbeddingClient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#9673A6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="560" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="c-emb-o" value="OllamaEmbeddingClient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="595" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="c-emb-s" value="SiliconFlowEmbeddingClient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="640" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="c-emb-b" value="BaiLianEmbeddingClient（可选）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="685" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="c-re-if" value="RerankClient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#9673A6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="560" width="180" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="c-re-b" value="BaiLianRerankClient&#xa;(qwen3-rerank)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="595" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="c-re-n" value="NoopRerankClient&#xa;(兜底，返回原序)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="650" width="180" height="50" as="geometry"/>
        </mxCell>

        <!-- model/ package -->
        <mxCell id="m-box" value="model/ — 模型选择与健康管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5E1D3;strokeColor=#AE7A4F;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="540" width="680" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="m-sel" value="ModelSelector&#xa;根据 request.deepThinking 等特征&#xa;从 ai.chat.candidates 或 ai.chat.deep-thinking-model&#xa;按 priority 排序，返回候选链" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AE7A4F;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="760" y="580" width="310" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="m-exec" value="ModelRoutingExecutor&#xa;for candidate : ordered:&#xa;  if health.isOpen(candidate): skip&#xa;  try: return client.invoke(candidate)&#xa;  catch: health.recordFailure(); continue&#xa;throw 所有候选都失败" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AE7A4F;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1080" y="580" width="330" height="130" as="geometry"/>
        </mxCell>

        <!-- health store -->
        <mxCell id="h-box" value="model/ModelHealthStore — Redis 熔断状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F5;strokeColor=#B85450;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="740" y="735" width="680" height="30" as="geometry"/>
        </mxCell>

        <!-- Streaming row -->
        <mxCell id="s-box" value="流式支撑（仅 Chat）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="790" width="1380" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="s-async" value="StreamAsyncExecutor&#xa;streamChat() 立即返回&#xa;真正调用在 modelStreamExecutor 线程池" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="830" width="300" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s-parser" value="OpenAIStyleSseParser&#xa;解析 OpenAI 格式 SSE&#xa;⚠️ 帧序：finish_reason → usage → [DONE]&#xa;循环退出看 streamEnded 不看 finished" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="400" y="830" width="340" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s-bridge" value="ProbeStreamBridge&#xa;首包探测 + 缓冲回放&#xa;⚠️ commit() 必须：snapshot+clear in lock，replay out of lock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="760" y="830" width="320" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s-cb" value="StreamCallback + TokenUsage&#xa;onContent · onThinking&#xa;onTokenUsage · onComplete · onError" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="830" width="320" height="90" as="geometry"/>
        </mxCell>

        <!-- External -->
        <mxCell id="ext" value="外部 LLM 供应商（HTTPS / OpenAI-compatible SSE）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="970" width="1380" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ext-e" style="endArrow=classic;html=1;strokeColor=#B85450;strokeWidth=2;" edge="1" parent="1" source="c-box" target="ext">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="endArrow=classic;html=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" parent="1" source="caller" target="if-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;strokeColor=#82B366;strokeWidth=2;" edge="1" parent="1" source="if-box" target="r-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;strokeColor=#9673A6;strokeWidth=2;" edge="1" parent="1" source="r-box" target="c-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;strokeColor=#AE7A4F;strokeWidth=2;dashed=1;" edge="1" parent="1" source="r-chat" target="m-sel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4-lbl" value="选择候选" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#AE7A4F;" vertex="1" parent="1">
          <mxGeometry x="510" y="495" width="80" height="18" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
