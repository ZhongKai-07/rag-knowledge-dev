        <mxCell id="fw-idem" value="idempotent/&#xa;@IdempotentSubmit/Consume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
