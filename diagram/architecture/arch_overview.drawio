          <mxGeometry x="1010" y="585" width="300" height="45" as="geometry"/>
        </mxCell>

        <!-- Edges: Bootstrap → framework / infra-ai -->
        <mxCell id="e2" style="endArrow=classic;html=1;strokeColor=#6C8EBF;strokeWidth=2;dashed=1;" edge="1" parent="1" source="bs-box" target="fw-box">
