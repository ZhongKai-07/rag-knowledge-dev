        <!-- Cross-cutting row -->
        <!-- framework -->
        <mxCell id="fw-box" value="framework — 跨切面基础设施（纯基础，无业务）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
