        <mxCell id="bs-user" value="user/ (31 文件)&#xa;Sa-Token 认证&#xa;RBAC · 部门 · security_level" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="320" width="210" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="bs-admin" value="admin/ (10) · core/ (17)&#xa;Dashboard KPI · Tika 解析&#xa;ChunkingStrategy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;fontSize=11;" vertex="1" parent="1">
