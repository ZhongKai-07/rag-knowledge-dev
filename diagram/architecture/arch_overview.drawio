        </mxCell>
        <mxCell id="ai-emb" value="embedding/&#xa;EmbeddingService → Routing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="950" y="530" width="180" height="50" as="geometry"/>
