        <mxCell id="infra-vector" value="向量库（三选一）&#xa;OpenSearch 2.18 · Milvus 2.6&#xa;pgvector&#xa;rag.vector.type 切换" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="750" width="210" height="100" as="geometry"/>
