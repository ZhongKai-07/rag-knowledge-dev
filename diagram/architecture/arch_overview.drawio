        <mxCell id="infra-rustfs" value="RustFS (S3 兼容)&#xa;原始文档存储&#xa;bucket = collectionName" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="880" y="750" width="190" height="100" as="geometry"/>
