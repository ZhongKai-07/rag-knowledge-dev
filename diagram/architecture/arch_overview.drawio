        <mxCell id="ai-rerank" value="rerank/&#xa;RerankService → Routing/Noop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
