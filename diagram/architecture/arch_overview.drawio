        </mxCell>
        <mxCell id="fw-web" value="web/&#xa;GlobalExceptionHandler · SseEmitterSender" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="490" y="585" width="170" height="45" as="geometry"/>
        </mxCell>

        <!-- infra-ai -->
        <mxCell id="ai-box" value="infra-ai — AI 能力抽象层（屏蔽多供应商差异）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="490" width="600" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="ai-chat" value="chat/&#xa;LLMService → RoutingLLMService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
