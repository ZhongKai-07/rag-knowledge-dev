        <mxCell id="infra-mq" value="RocketMQ 5.x&#xa;文档分块事务消息&#xa;@IdempotentConsume" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="750" width="170" height="100" as="geometry"/>
