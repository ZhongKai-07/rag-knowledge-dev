<mxfile host="app.diagrams.net">
  <diagram id="arch-overview" name="总览 · 四层分层">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="HT KnowledgeBase — 系统总览（四层分层架构）" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Frontend (SPA)  →  Bootstrap (业务域)  →  framework + infra-ai (跨切面基础设施)  →  Infrastructure (中间件 + 外部 LLM)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1320" height="22" as="geometry"/>
        </mxCell>

        <!-- Frontend Layer -->
        <mxCell id="fe-box" value="Frontend Layer — React 18 + Vite + TypeScript" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="1240" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="fe-pages" value="pages/&#xa;（SpacesPage · ChatPage · admin/*）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="110" y="140" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="fe-components" value="components/&#xa;（ui/shadcn · chat · layout · admin）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="140" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="fe-stores" value="stores/ (Zustand)&#xa;chatStore · authStore" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="140" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="fe-services" value="services/ (Axios)&#xa;统一 {code, data, message} 拦截" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="140" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="fe-guards" value="router/guards + utils/permissions&#xa;Sa-Token Bearer-less Header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1110" y="140" width="190" height="70" as="geometry"/>
        </mxCell>

        <!-- Edge: FE → Bootstrap -->
        <mxCell id="e1" style="endArrow=classic;html=1;strokeColor=#444;strokeWidth=2;" edge="1" parent="1" source="fe-box" target="bs-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1-label" value="HTTPS REST + SSE&#xa;(/api/ragent/*)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="238" width="200" height="32" as="geometry"/>
        </mxCell>

        <!-- Bootstrap Layer -->
        <mxCell id="bs-box" value="Bootstrap Layer — Spring Boot 3.5.7 · 端口 9090 · /api/ragent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
