                <mxCell id="bootstrap" value="EC2 Auto Scaling Group&#xa;━━━━━━━━━━━━&#xa;Bootstrap (Spring Boot 9090)&#xa;• 无状态 HTTP + SSE&#xa;• Apache Tika 内嵌（当前）&#xa;• Spring Event + @Async&#xa;  (替代 RocketMQ)&#xa;• 恢复 Job 扫 status=RUNNING&gt;10min&#xa;• 优雅停机 drain 线程池" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" parent="1" vertex="1">
                    <mxGeometry x="330" y="440" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="mcp" value="EC2: MCP Server&#xa;━━━━━━━━━━━━&#xa;• 内网仅对 Bootstrap 暴露&#xa;• 不接 ALB&#xa;• Model Context Protocol&#xa;  工具调用后端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" parent="1" vertex="1">
                    <mxGeometry x="650" y="440" width="230" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="spring-event" value="🔁 进程内事件总线&#xa;━━━━━━━━━━━━&#xa;ApplicationEventPublisher&#xa;→ @EventListener @Async&#xa;━━━━━━━━━━━━&#xa;• DocChunkRequestedEvent&#xa;• BdaCompletedEvent (future)&#xa;&#xa;持久化态 = t_knowledge_document.status&#xa;事件只是触发器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="920" y="440" width="240" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="vpce-s3" value="VPC Endpoint&#xa;(S3 Gateway)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8DC;strokeColor=#455A64;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1200" y="460" width="130" height="50" as="geometry"/>
