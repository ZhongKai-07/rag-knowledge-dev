          <mxGeometry x="1430" y="295" width="150" height="65" as="geometry" />
        </mxCell>

        <!-- Private App Subnet -->
        <mxCell id="app-subnet" value="Private Subnet — App Tier (跨 AZ-a / AZ-b)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3949AB;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="300" y="400" width="1310" height="230" as="geometry" />
        </mxCell>

        <!-- Bootstrap ASG -->
        <mxCell id="bootstrap" value="EC2 Auto Scaling Group&#10;━━━━━━━━━━━━&#10;Bootstrap (Spring Boot 9090)&#10;• 无状态 HTTP + SSE&#10;• Apache Tika 内嵌（当前）&#10;• Spring Event + @Async&#10;  (替代 RocketMQ)&#10;• 恢复 Job 扫 status=RUNNING&gt;10min&#10;• 优雅停机 drain 线程池" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="330" y="440" width="280" height="170" as="geometry" />
        </mxCell>

        <!-- MCP -->
        <mxCell id="mcp" value="EC2: MCP Server&#10;━━━━━━━━━━━━&#10;• 内网仅对 Bootstrap 暴露&#10;• 不接 ALB&#10;• Model Context Protocol&#10;  工具调用后端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="650" y="440" width="230" height="130" as="geometry" />
        </mxCell>

        <!-- In-process Spring Event annotation -->
        <mxCell id="spring-event" value="🔁 进程内事件总线&#10;━━━━━━━━━━━━&#10;ApplicationEventPublisher&#10;→ @EventListener @Async&#10;━━━━━━━━━━━━&#10;• DocChunkRequestedEvent&#10;• BdaCompletedEvent (future)&#10;&#10;持久化态 = t_knowledge_document.status&#10;事件只是触发器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="920" y="440" width="240" height="170" as="geometry" />
        </mxCell>

        <!-- VPC Endpoint -->
        <mxCell id="vpce-s3" value="VPC Endpoint&#10;(S3 Gateway)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8DC;strokeColor=#455A64;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="460" width="130" height="50" as="geometry" />
        </mxCell>

        <mxCell id="vpce-bedrock" value="VPC Endpoint&#10;(Bedrock / BDA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8DC;strokeColor=#455A64;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="540" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Private Data Subnet -->
        <mxCell id="data-subnet" value="Private Subnet — Data Tier (Multi-AZ, 无公网出口)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
