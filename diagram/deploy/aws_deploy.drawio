        <mxCell id="subtitle" value="简化方案：去 RocketMQ（Spring Event 替代）；BDA 以 SNS Webhook 回调接入（虚线表示未来）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#666666" vertex="1" parent="1">
