        <!-- Title -->
        <mxCell id="title" value="HT KnowledgeBase — AWS 物理部署示意图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1" vertex="1" parent="1">
