        </mxCell>

        <!-- RDS -->
        <mxCell id="rds" value="RDS for PostgreSQL&#10;━━━━━━━━━━━━&#10;Multi-AZ 主备&#10;• 业务 + 会话 + 链路 + 评测&#10;• 非 pgvector 模式" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="700" width="230" height="130" as="geometry" />
