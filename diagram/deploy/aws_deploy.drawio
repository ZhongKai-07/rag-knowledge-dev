        <!-- Note: no RocketMQ -->
        <mxCell id="no-mq" value="❌ 取消 RocketMQ&#10;━━━━━━━━━━━━&#10;改用 Spring Event&#10;+ DB 状态机&#10;+ 恢复补偿 Job" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="700" width="190" height="130" as="geometry" />
