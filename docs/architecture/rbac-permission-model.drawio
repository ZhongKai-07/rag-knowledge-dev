<mxfile host="app.diagrams.net" modified="2026-04-14T00:00:00.000Z" agent="Claude" version="24.0.0" type="device">
  <diagram id="rbac-overview" name="权限管理总览">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ========== 标题 ========== -->
        <mxCell id="title" value="RAG 系统权限管理架构" style="text;html=1;align=center;verticalAlign=middle;fontSize=28;fontStyle=1;fontColor=#1a1a2e;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="四层防御 · 三级角色 · 文档安全等级" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#6c757d;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="400" y="65" width="800" height="30" as="geometry"/>
        </mxCell>

        <!-- ========== Layer 4: 前端层 ========== -->
        <mxCell id="layer4-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;strokeWidth=2;arcSize=8;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="1520" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="layer4-label" value="Layer 4 — 前端" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#2e7d32;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="55" y="115" width="150" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="fe-guard" value="&lt;b&gt;路由守卫&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;RequireAuth&lt;br&gt;RequireAnyAdmin&lt;br&gt;RequireSuperAdmin&lt;br&gt;RequireMenuAccess&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4caf50;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="80" y="145" width="160" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="fe-perm" value="&lt;b&gt;permissions.ts&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;权限计算中心&lt;br&gt;canSeeMenuItem / canManageKb&lt;br&gt;canManageUser / canAssignRole&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4caf50;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="280" y="145" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="fe-sidebar" value="&lt;b&gt;AdminLayout 侧边栏&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;按 canSeeMenuItem 过滤&lt;br&gt;DEPT_ADMIN 仅 4 项&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4caf50;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="540" y="145" width="180" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="fe-degrade" value="&lt;b&gt;优雅降级&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;后端拒绝 → return null&lt;br&gt;不弹 toast，静默隐藏&lt;br&gt;(KbSharingTab 模式)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4caf50;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="760" y="145" width="180" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="fe-token" value="&lt;b&gt;Token 机制&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Authorization: &amp;lt;token&amp;gt;&lt;br&gt;无 Bearer 前缀&lt;br&gt;HTTP 200 + code!=&quot;0&quot; 表拒绝&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4caf50;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="980" y="145" width="190" height="75" as="geometry"/>
        </mxCell>

        <!-- ========== Layer 3: 拦截器层 ========== -->
        <mxCell id="layer3-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#2196f3;strokeWidth=2;arcSize=8;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="1520" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="layer3-label" value="Layer 3 — 后端拦截器链" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#1565c0;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="55" y="255" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="interceptor1" value="&lt;b&gt;SaInterceptor&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;checkLogin()&lt;br&gt;仅校验登录状态&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2196f3;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="80" y="285" width="170" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-i1" value="" style="endArrow=block;endFill=1;strokeColor=#2196f3;strokeWidth=2;" edge="1" parent="1" source="interceptor1" target="interceptor2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="interceptor2" value="&lt;b&gt;DemoModeInterceptor&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;演示环境写入拦截&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2196f3;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="340" y="285" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-i2" value="" style="endArrow=block;endFill=1;strokeColor=#2196f3;strokeWidth=2;" edge="1" parent="1" source="interceptor2" target="interceptor3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="interceptor3" value="&lt;b&gt;UserContextInterceptor&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;UserProfileLoader.load()&lt;br&gt;→ UserContext ThreadLocal&lt;br&gt;每请求 3~4 次 SQL 不缓存&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2196f3;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="610" y="285" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-i3" value="" style="endArrow=block;endFill=1;strokeColor=#2196f3;strokeWidth=2;" edge="1" parent="1" source="interceptor3" target="controller-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="controller-box" value="&lt;b&gt;Controller&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;@SaCheckRole / KbAccessService&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="920" y="285" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- ========== Layer 2: 权限引擎 ========== -->
        <mxCell id="layer2-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;strokeWidth=2;arcSize=8;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="1520" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="layer2-label" value="Layer 2 — 业务层权限引擎（KbAccessService）" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#e65100;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="55" y="385" width="400" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="kas-access" value="&lt;b&gt;checkAccess(kbId)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;READ 权限校验&lt;br&gt;SUPER_ADMIN → pass&lt;br&gt;DEPT_ADMIN 同部门 → pass&lt;br&gt;否则查 RBAC 绑定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="195" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="kas-manage" value="&lt;b&gt;checkManageAccess(kbId)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;管理权限校验&lt;br&gt;SUPER_ADMIN → pass&lt;br&gt;DEPT_ADMIN 同部门 → pass&lt;br&gt;USER → &lt;font color=&quot;#d32f2f&quot;&gt;始终拒绝&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="310" y="420" width="210" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="kas-kbids" value="&lt;b&gt;getAccessibleKbIds()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;可访问 KB 集合&lt;br&gt;SUPER_ADMIN → 全部(无缓存)&lt;br&gt;DEPT_ADMIN → 部门∪RBAC(缓存)&lt;br&gt;USER → RBAC(缓存 30min)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="555" y="420" width="225" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="kas-security" value="&lt;b&gt;getMaxSecurityLevelForKb()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;文档密级上限解析&lt;br&gt;SUPER_ADMIN → 3&lt;br&gt;DEPT_ADMIN 同部门 → 角色上限&lt;br&gt;其他 → MAX(RBAC 绑定级别)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="815" y="420" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="kas-assign" value="&lt;b&gt;checkAssignRolesAccess()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;角色分配校验&lt;br&gt;DEPT_ADMIN 不可分配&lt;br&gt;SUPER_ADMIN / DEPT_ADMIN 角色&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff9800;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="1080" y="420" width="215" height="80" as="geometry"/>
        </mxCell>

        <!-- 缓存策略 -->
        <mxCell id="cache-box" value="&lt;b&gt;Redis 缓存策略&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;kb_access:{userId} — KB 集合 (30min)&lt;br&gt;kb_security_level:{userId} — 密级 Map (30min)&lt;br&gt;角色/绑定变更 → 遍历受影响用户 → evictCache&lt;br&gt;SUPER_ADMIN 不缓存，WRITE/MANAGE 查询跳过缓存&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffa000;strokeWidth=1;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="80" y="515" width="460" height="55" as="geometry"/>
        </mxCell>
        <!-- 最后管理员保护 -->
        <mxCell id="last-admin" value="&lt;b&gt;SuperAdminMutationIntent&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;删用户/删角色/降级角色/替换角色 → 模拟操作后 SUPER_ADMIN 计数&lt;br&gt;计数 &amp;lt; 1 → &lt;font color=&quot;#d32f2f&quot;&gt;拒绝操作&lt;/font&gt; (系统级硬不变量)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#d32f2f;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="580" y="515" width="460" height="55" as="geometry"/>
        </mxCell>

        <!-- ========== Layer 1: 数据模型 ========== -->
        <mxCell id="layer1-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e91e63;strokeWidth=2;arcSize=8;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="1520" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="layer1-label" value="Layer 1 — 数据模型" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#c2185b;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="55" y="605" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="dept" value="&lt;b&gt;sys_dept&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id&lt;br&gt;deptCode (UNIQUE)&lt;br&gt;deptName&lt;/font&gt;" style="shape=table;startSize=0;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e91e63;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="user" value="&lt;b&gt;t_user&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id · username · password&lt;br&gt;dept_id → sys_dept&lt;br&gt;deleted (@TableLogic)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e91e63;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="300" y="640" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="user-role" value="&lt;b&gt;t_user_role&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;user_id → t_user&lt;br&gt;role_id → t_role&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e91e63;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="550" y="640" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="role" value="&lt;b&gt;t_role&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id · name · description&lt;br&gt;&lt;font color=&quot;#d32f2f&quot;&gt;role_type&lt;/font&gt;: SUPER_ADMIN|DEPT_ADMIN|USER&lt;br&gt;&lt;font color=&quot;#1565c0&quot;&gt;max_security_level&lt;/font&gt;: 0~3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e91e63;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="770" y="635" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="role-kb" value="&lt;b&gt;t_role_kb_relation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;role_id → t_role&lt;br&gt;kb_id → t_knowledge_base&lt;br&gt;&lt;font color=&quot;#d32f2f&quot;&gt;permission&lt;/font&gt;: READ|WRITE|MANAGE&lt;br&gt;&lt;font color=&quot;#1565c0&quot;&gt;max_security_level&lt;/font&gt;: 0~3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e91e63;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="1070" y="632" width="210" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="kb" value="&lt;b&gt;t_knowledge_base&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id · name&lt;br&gt;dept_id → sys_dept&lt;br&gt;collection_name&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e91e63;strokeWidth=1.5;shadow=1;fontSize=11;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="1350" y="640" width="170" height="70" as="geometry"/>
        </mxCell>

        <!-- ER 箭头 -->
        <mxCell id="er1" value="1:N" style="endArrow=ERmany;endFill=0;startArrow=ERone;startFill=0;strokeColor=#ad1457;strokeWidth=1.5;fontSize=10;fontColor=#ad1457;" edge="1" parent="1" source="dept" target="user">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="er2" value="1:N" style="endArrow=ERmany;endFill=0;startArrow=ERone;startFill=0;strokeColor=#ad1457;strokeWidth=1.5;fontSize=10;fontColor=#ad1457;" edge="1" parent="1" source="user" target="user-role">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="er3" value="N:1" style="endArrow=ERone;endFill=0;startArrow=ERmany;startFill=0;strokeColor=#ad1457;strokeWidth=1.5;fontSize=10;fontColor=#ad1457;" edge="1" parent="1" source="user-role" target="role">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="er4" value="1:N" style="endArrow=ERmany;endFill=0;startArrow=ERone;startFill=0;strokeColor=#ad1457;strokeWidth=1.5;fontSize=10;fontColor=#ad1457;" edge="1" parent="1" source="role" target="role-kb">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="er5" value="N:1" style="endArrow=ERone;endFill=0;startArrow=ERmany;startFill=0;strokeColor=#ad1457;strokeWidth=1.5;fontSize=10;fontColor=#ad1457;" edge="1" parent="1" source="role-kb" target="kb">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- dept -> kb -->
        <mxCell id="er6" value="" style="endArrow=ERmany;endFill=0;startArrow=ERone;startFill=0;strokeColor=#ad1457;strokeWidth=1;dashed=1;fontSize=10;fontColor=#ad1457;" edge="1" parent="1" source="dept" target="kb">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="155" y="760"/>
              <mxPoint x="1435" y="760"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="er6-label" value="dept_id" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#ad1457;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="740" y="740" width="80" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="role-matrix" name="角色权限矩阵">
    <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 标题 -->
        <mxCell id="m-title" value="角色权限矩阵" style="text;html=1;align=center;verticalAlign=middle;fontSize=26;fontStyle=1;fontColor=#1a1a2e;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="800" height="45" as="geometry"/>
        </mxCell>

        <!-- ==================== 角色卡片 ==================== -->

        <!-- SUPER_ADMIN -->
        <mxCell id="sa-card" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;strokeWidth=2;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="400" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="sa-badge" value="SUPER_ADMIN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3f51b5;strokeColor=none;fontColor=#ffffff;fontStyle=1;fontSize=14;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="55" y="95" width="170" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="sa-desc" value="&lt;font style=&quot;font-size:11px&quot;&gt;超级管理员 — 全局最高权限&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontColor=#5c6bc0;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="235" y="95" width="195" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="sa-content" value="&lt;div style=&quot;text-align:left;font-size:11px;line-height:1.8&quot;&gt;&lt;b&gt;知识库访问:&lt;/b&gt; 全部 KB，无过滤，无缓存&lt;br&gt;&lt;b&gt;知识库管理:&lt;/b&gt; 全部 KB 可增删改&lt;br&gt;&lt;b&gt;文档安全等级:&lt;/b&gt; 固定返回 3（最高）&lt;br&gt;&lt;b&gt;用户管理:&lt;/b&gt; 所有部门用户可管理&lt;br&gt;&lt;b&gt;角色分配:&lt;/b&gt; 不限，可分配任何角色类型&lt;br&gt;&lt;b&gt;KB 共享管理:&lt;/b&gt; 任意 KB&lt;br&gt;&lt;b&gt;部门管理:&lt;/b&gt; 可增删改部门&lt;br&gt;&lt;b&gt;系统设置:&lt;/b&gt; 意图树 · 入库管道 · 追踪 · 评测&lt;br&gt;&lt;b&gt;特殊:&lt;/b&gt; &lt;font color=&quot;#d32f2f&quot;&gt;最后一个不可删/不可降级&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontFamily=Microsoft YaHei;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="135" width="370" height="200" as="geometry"/>
        </mxCell>

